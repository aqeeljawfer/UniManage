@model List<Message>
@{ ViewData["Title"] = "Inbox"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-envelope me-2" style="color:#048A81"></i>Inbox</h2>
    <div class="d-flex gap-2">
        <a asp-action="Sent" class="btn btn-outline-secondary"><i class="bi bi-send me-1"></i>Sent</a>
        <a asp-action="Compose" class="btn btn-acc"><i class="bi bi-pencil-square me-1"></i>Compose</a>
    </div>
</div>
@if (!Model.Any()) { <div class="alert alert-info text-center py-5"><i class="bi bi-inbox fs-1 d-block mb-3 text-muted"></i>Your inbox is empty.</div> }
else {
    <div class="card">
        <div class="card-body p-0">
            @foreach (var m in Model) {
                <a asp-action="Read" asp-route-id="@m.MessageId" class="d-flex align-items-center p-3 border-bottom text-decoration-none text-dark @(m.IsRead?"":"bg-light fw-bold")">
                    <div class="me-3"><i class="bi @(m.IsRead?"bi-envelope-open text-muted":"bi-envelope-fill text-primary") fs-5"></i></div>
                    <div class="flex-grow-1">
                        <div>@m.Sender?.FullName</div>
                        <div class="small text-muted">@m.Subject</div>
                    </div>
                    <small class="text-muted ms-3 text-nowrap">@m.SentAt.ToString("dd MMM HH:mm")</small>
                </a>
            }
        </div>
    </div>
}
