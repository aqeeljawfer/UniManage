@model LecturerDashVM
@{ ViewData["Title"] = "Lecturer Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <div><h2 class="fw-bold mb-0"><i class="bi bi-easel me-2" style="color:#048A81"></i>Lecturer Dashboard</h2>
    <p class="text-muted mb-0">Welcome, <strong>@Model.LecturerName</strong></p></div>
    <a asp-action="CreateAssignment" class="btn btn-acc"><i class="bi bi-plus-circle me-2"></i>New Assignment</a>
</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-primary">@Model.Courses.Count</div><div class="text-muted small">My Courses</div></div></div>
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-success">@Model.TotalStudents</div><div class="text-muted small">Total Students</div></div></div>
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-warning">@Model.PendingGrading</div><div class="text-muted small">Pending Grading</div></div></div>
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-danger">@Model.UnreadMessages</div><div class="text-muted small">Unread Messages</div></div></div>
</div>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold text-white" style="background:#2E4057"><i class="bi bi-book me-2"></i>My Courses</div>
            <div class="card-body p-0">
                @if (!Model.Courses.Any()) { <div class="p-4 text-center text-muted">No courses assigned.</div> }
                else {
                    <ul class="list-group list-group-flush">
                        @foreach (var c in Model.Courses) {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div><div class="fw-semibold">@c.Title</div><small class="text-muted">@c.CurrentEnrollment/@c.MaxCapacity enrolled</small></div>
                                <a asp-action="CourseStudents" asp-route-courseId="@c.CourseId" class="btn btn-sm btn-outline-primary"><i class="bi bi-people me-1"></i>Students</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-bold text-white" style="background:#048A81"><i class="bi bi-check2-square me-2"></i>Grading Summary</div>
            <div class="card-body p-0">
                @if (!Model.Summaries.Any()) { <div class="p-4 text-center text-muted">No submissions yet.</div> }
                else {
                    <ul class="list-group list-group-flush">
                        @foreach (var s in Model.Summaries) {
                            var pct = s.Total > 0 ? (int)(s.Graded * 100.0 / s.Total) : 0;
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="fw-semibold small">@s.CourseName</span>
                                    <span class="small text-muted">@s.Graded/@s.Total graded</span>
                                </div>
                                <div class="progress" style="height:8px"><div class="progress-bar bg-success" style="width:@pct%"></div></div>
                                @if (s.Pending > 0) { <small class="text-warning"><i class="bi bi-exclamation-triangle me-1"></i>@s.Pending pending</small> }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
