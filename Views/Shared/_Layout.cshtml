<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UniManage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root {
            --pri: #2E4057;
            --acc: #048A81;
        }

        body {
            background: #f4f6f9;
            font-family: 'Segoe UI',sans-serif;
        }

        .navbar {
            background: var(--pri) !important;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
        }

        .sidebar {
            background: var(--pri);
            min-height: calc(100vh - 56px);
            padding-top: 1rem;
        }

            .sidebar .nav-link {
                color: rgba(255,255,255,.75);
                border-radius: 6px;
                margin: 2px 8px;
                padding: 8px 12px;
            }

                .sidebar .nav-link:hover {
                    background: var(--acc);
                    color: #fff;
                }

                .sidebar .nav-link i {
                    margin-right: 8px;
                }

        .content-area {
            padding: 1.5rem;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
        }

        .badge-A {
            background: #28a745;
            color: #fff;
        }

        .badge-B {
            background: #17a2b8;
            color: #fff;
        }

        .badge-C {
            background: #ffc107;
            color: #000;
        }

        .badge-D {
            background: #fd7e14;
            color: #fff;
        }

        .badge-F {
            background: #dc3545;
            color: #fff;
        }

        .table thead th {
            background: var(--pri);
            color: #fff;
        }

        .toast-box {
            position: fixed;
            top: 70px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }

        .btn-pri {
            background: var(--pri);
            color: #fff;
        }

            .btn-pri:hover {
                background: #1e2d3d;
                color: #fff;
            }

        .btn-acc {
            background: var(--acc);
            color: #fff;
        }

            .btn-acc:hover {
                background: #036d65;
                color: #fff;
            }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>

<nav class="navbar navbar-dark navbar-expand-lg">
    <div class="container-fluid">
        <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
            <i class="bi bi-mortarboard-fill me-2"></i>UniManage
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item me-3">
                        <span class="text-white-50 small"><i class="bi bi-person-circle me-1"></i>@User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Message" asp-action="Inbox" title="Messages">
                            <i class="bi bi-envelope fs-5"></i>
                        </a>
                    </li>
                    <li class="nav-item ms-2">
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </button>
                        </form>
                    </li>
                </ul>
            }
            else
            {
                @*<ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a></li>
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="Account" asp-action="Register">Register</a></li>
                </ul>*@
            }
        </div>
    </div>
</nav>

<div class="container-fluid">
    <div class="row">

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="col-lg-2 col-md-3 d-none d-md-block p-0 sidebar">
                <nav class="nav flex-column pt-2">
                    @if (User.IsInRole("Student"))
                    {
                        <a class="nav-link" asp-controller="Student" asp-action="Dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a>
                        <a class="nav-link" asp-controller="Student" asp-action="BrowseCourses"><i class="bi bi-search"></i>Browse Courses</a>
                        <a class="nav-link" asp-controller="Student" asp-action="Assignments"><i class="bi bi-file-earmark-text"></i>Assignments</a>
                        <a class="nav-link" asp-controller="Student" asp-action="Grades"><i class="bi bi-award"></i>My Grades</a>
                        <a class="nav-link" asp-controller="Message" asp-action="Inbox"><i class="bi bi-envelope"></i>Messages</a>
                    }
                    @if (User.IsInRole("Lecturer"))
                    {
                        <a class="nav-link" asp-controller="Lecturer" asp-action="Dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a>
                        <a class="nav-link" asp-controller="Lecturer" asp-action="Assignments"><i class="bi bi-file-earmark-text"></i>Assignments</a>
                        <a class="nav-link" asp-controller="Message" asp-action="Inbox"><i class="bi bi-envelope"></i>Messages</a>
                    }
                    @if (User.IsInRole("Administrator"))
                    {
                        <a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i>Dashboard</a>
                        <a class="nav-link" asp-controller="Admin" asp-action="Courses"><i class="bi bi-book"></i>Courses</a>
                        <a class="nav-link" asp-controller="Admin" asp-action="Users"><i class="bi bi-people"></i>Users</a>
                        <a class="nav-link" asp-controller="Admin" asp-action="Reports"><i class="bi bi-bar-chart"></i>Reports</a>
                        <a class="nav-link" asp-controller="Message" asp-action="Inbox"><i class="bi bi-envelope"></i>Messages</a>
                    }
                </nav>
            </div>
            <div class="col-lg-10 col-md-9 content-area">
                @if (TempData["Success"] != null)
                {
                    <script>
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: '@TempData["Success"]',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 4000,
                            timerProgressBar: true
                        });
                    </script>
                }
                @if (TempData["Error"] != null)
                {
                    <script>
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: '@TempData["Error"]',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 4000,
                            timerProgressBar: true
                        });
                    </script>
                }
                @RenderBody()
            </div>
        }
        else
        {
            <div class="col-12 content-area">
                @RenderBody()
            </div>
        }

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
