@model List<Course>
@{ ViewData["Title"] = "Manage Courses"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-book me-2" style="color:#048A81"></i>Manage Courses</h2>
    <a asp-action="CreateCourse" class="btn btn-acc"><i class="bi bi-plus-circle me-2"></i>New Course</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead><tr><th>Title</th><th>Credits</th><th>Lecturer</th><th>Capacity</th><th>Enrolled</th><th>Actions</th></tr></thead>
            <tbody>
                @foreach (var c in Model) {
                <tr>
                    <td class="fw-semibold">@c.Title</td>
                    <td>@c.Credits</td>
                    <td>@(c.Lecturer?.FullName ?? "—")</td>
                    <td>@c.MaxCapacity</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @c.CurrentEnrollment
                        <div class="progress flex-grow-1" style="height:6px;min-width:50px">
                            <div class="progress-bar" style="width:@(c.MaxCapacity>0?c.CurrentEnrollment*100/c.MaxCapacity:0)%;background:#048A81"></div>
                        </div>
                    </div>
                </td>
                <td>
                    <a asp-action="EditCourse" asp-route-id="@c.CourseId" class="btn btn-sm delete-form btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                    <form asp-action="DeleteCourse" method="post" class="d-inline delete-form" data-title="@c.Title" >
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@c.CourseId" />
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
                }
            </tbody>
            <script>
                document.querySelectorAll('.delete-form').forEach(form => {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();

                        let title = this.getAttribute('data-title');

                        Swal.fire({
                            title: 'Are you sure?',
                            text: `Delete ${title}?`,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: '#d33',
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Yes, delete it!'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                form.submit();
                            }
                        });
                    });
                });
            </script>

        </table>
    </div>
</div>
