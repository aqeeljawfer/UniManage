@model AdminDashVM
@{ ViewData["Title"] = "Admin Dashboard"; }
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-shield-check me-2" style="color:#048A81"></i>Admin Dashboard</h2>
    <a asp-action="CreateCourse" class="btn btn-acc"><i class="bi bi-plus-circle me-2"></i>New Course</a>
</div>
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center p-3">
            <div class="fw-bold fs-1 text-primary">@Model.TotalStudents</div>
            <div class="text-muted small">Students</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center p-3">
            <div class="fw-bold fs-1 text-success">@Model.TotalLecturers</div>
            <div class="text-muted small">Lecturers</div>
        </div>
    </div>
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-warning">@Model.TotalCourses</div><div class="text-muted small">Courses</div></div></div>
    <div class="col-6 col-md-3"><div class="card text-center p-3"><div class="fw-bold fs-1 text-danger">@Model.TotalEnrollments</div><div class="text-muted small">Enrollments</div></div></div>
</div>
<div class="row g-4">
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header fw-bold text-white" style="background:#2E4057"><i class="bi bi-bar-chart me-2"></i>Enrollment by Course</div>
            <div class="card-body"><canvas id="enrollChart" height="230"></canvas></div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header fw-bold text-white" style="background:#048A81"><i class="bi bi-clock-history me-2"></i>Recent Courses</div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    @foreach (var c in Model.RecentCourses) {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div><div class="fw-semibold small">@c.Title</div><small class="text-muted">@(c.Lecturer?.FullName ?? "Unassigned")</small></div>
                        <span class="badge bg-primary">@c.CurrentEnrollment</span>
                    </li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
    var labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Stats.Select(s => s.CourseName)));
    var counts = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Stats.Select(s => s.Count)));

    new Chart(document.getElementById('enrollChart'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{
                label: 'Enrollments',
                data: counts,
                backgroundColor: 'rgba(4,138,129,0.7)',
                borderColor: 'rgba(4,138,129,1)',
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            }
        }
    });
    </script>
}

